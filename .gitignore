# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode — per-user state (schemes management, breakpoints, UI state); not needed to build
**/xcuserdata/
*.xccheckout
*.xcscmblueprint
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build products and caches (regenerated by Xcode)
build/
DerivedData/
.derivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# SwiftPM local build artifacts (dependencies resolve via committed Package.resolved)
.build/

# Commit these: project.pbxproj, **/xcshareddata/** (shared schemes, swiftpm/Package.resolved)

# CocoaPods / Carthage
Pods/
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Other IDEs / editors
.idea/
*.swp
*~

# Temp / logs
*.log
*.tmp
